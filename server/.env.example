# ── Agent Chat Widget — server configuration ─────────────────────────────────
# Copy to server/.env and fill in. Only the SSO pair is required for SSO login;
# password (agentVep) login needs no extra config.
#
# The model: ONE backend serves BOTH the widget UI (/widget) AND the /api routes,
# so everything is same-origin — cookies, the SSO redirect, and the cobrowse room
# all key off whatever origin the page is loaded from. You only change the origin
# per environment (local / tunnel / Cloud Run); the code adapts automatically.

# HTTP port the Express server serves the SPA + /api on. 9400 in local prod-style
# so the SSO callback origin is http://localhost:9400. On Cloud Run, the platform
# sets $PORT — leave this unset there (the server reads process.env.PORT).
PORT=9400

# ── Cobrowse / video / voice room (HTTPS) ────────────────────────────────────
# The synchronite room must be served over TLS. Two modes:
#
#   • Local dev (plain-http localhost): we run a self-signed HTTPS server on this
#     port for the room only. Trust it once at https://localhost:9443/api/health.
COBROWSE_HTTPS_PORT=9443
#
#   • Managed TLS (Cloud Run, a tunnel like ngrok/cloudflared, or any reverse proxy
#     terminating HTTPS): set COBROWSE_HTTPS_ORIGIN to that public https origin. The
#     local :9443 server is then auto-disabled and the room serves from the main
#     origin. Examples:
# COBROWSE_HTTPS_ORIGIN=https://your-app-abc123.run.app
# COBROWSE_HTTPS_ORIGIN=https://your-tunnel.ngrok-free.app

# ── SSO (LP Sentinel OAuth2) ─────────────────────────────────────────────────
# Client id/secret from the LP OAuth app. The redirect URIs below MUST be
# registered in that OAuth app AND match the origin you serve from.
#   • Full console SSO returns to:  <origin>/callback
#   • Widget SSO (popup) returns to: <origin>/widget/callback
# Add each environment's URLs here and in the OAuth app.
#   local:     http://localhost:9400/callback , http://localhost:9400/widget/callback
#   tunnel:    https://<tunnel-host>/callback , https://<tunnel-host>/widget/callback
#   cloud run: https://<service>.run.app/callback , https://<service>.run.app/widget/callback
LP_SSO_CLIENT_ID=
LP_SSO_CLIENT_SECRET=
LP_SSO_REDIRECT_URIS=http://localhost:9400/callback,http://localhost:9400/widget/callback

# ── Embedding the widget cross-site ──────────────────────────────────────────
# Only needed if the widget <iframe> is hosted on a DIFFERENT origin than this
# server (not the recommended setup — prefer pointing the iframe at THIS server's
# /widget so it's same-origin). When cross-site, the session cookie must be
# SameSite=None; Secure (requires HTTPS). Set to 1 to enable.
# WIDGET_CROSS_SITE_COOKIE=1
